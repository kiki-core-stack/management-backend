{
  "type": "module",
  "private": true,
  "scripts": {
    "base:dev": "cross-env NODE_ENV=development bun --env-file=./.env.development.local",
    "base:prod": "cross-env NODE_ENV=production bun --env-file=./.env.production.local",
    "bootstrap:dev": "bun run base:dev -- run ./src/core/bootstrap/index.ts",
    "bootstrap:prod": "bun run base:prod -- run ./src/core/bootstrap/index.ts",
    "build": "bun run base:prod -- run ./src/core/build.ts",
    "dev": "cross-env NODE_ENV=development nodemon",
    "knip:deps": "knip --dependencies",
    "knip:exports": "knip --exports",
    "lint": "eslint --max-warnings 0",
    "lint:fix": "eslint --fix --max-warnings 0",
    "typecheck": "tsc"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.7.6",
    "@kiki-core-stack/pack": "^0.94.3",
    "@kikiutils/micromatch": "^4.0.9",
    "@kikiutils/mongoose": "^7.0.1",
    "@kikiutils/shared": "^14.1.2",
    "@sylke/email-validation": "^1.0.0",
    "consola": "^3.4.2",
    "date-fns": "^4.1.0",
    "es-toolkit": "^1.45.1",
    "file-type": "^21.3.1",
    "flat": "^6.0.1",
    "hono": "^4.12.5",
    "lru-cache": "^11.2.6",
    "mongoose": "^9.2.4",
    "msgpackr": "^1.11.8",
    "nanoid": "^5.1.6",
    "node-ciphers": "^6.1.4",
    "on-change": "^6.0.2",
    "sharp": "^0.34.5",
    "svg-captcha": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.7.0",
    "@asteasolutions/zod-to-openapi": "^8.4.3",
    "@hono/swagger-ui": "^0.6.0",
    "@kikiutils/eslint-config": "^7.0.2",
    "@kikiutils/tsconfigs": "^5.1.0",
    "@scalar/hono-api-reference": "^0.10.0",
    "@types/bun": "^1.3.10",
    "@types/micromatch": "^4.0.10",
    "cross-env": "^10.1.0",
    "knip": "^5.86.0",
    "mlly": "^1.8.1",
    "nodemon": "^3.1.14",
    "openapi3-ts": "^4.5.0",
    "type-fest": "^5.4.4",
    "typescript": "^5.9.3",
    "unimport": "^6.0.1"
  }
