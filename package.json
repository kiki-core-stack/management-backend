    "@kikiutils/micromatch": "^4.0.9",
    "@kikiutils/mongoose": "^7.0.2",
    "@kikiutils/shared": "^16.0.0",
    "@sylke/email-validation": "^1.0.0",
    "consola": "^3.4.2",
    "date-fns": "^4.4.0",
    "es-toolkit": "^1.49.0",
    "file-type": "^22.0.1",
    "flat": "^6.0.1",
    "hono": "^4.12.30",
    "lru-cache": "^11.5.2",
    "mongoose": "^9.7.4",
    "msgpackr": "^2.0.4",
    "nanoid": "^6.0.0",
    "node-ciphers": "^6.1.4",
    "on-change": "^6.0.2",
    "sharp": "^0.35.3",
    "svg-captcha": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.1.0",
    "@asteasolutions/zod-to-openapi": "^9.0.0",
    "@hono/swagger-ui": "^0.6.1",
    "@kikiutils/eslint-config": "^9.2.0",
    "@kikiutils/tsconfigs": "^7.0.0",
    "@scalar/hono-api-reference": "^0.11.9",
    "@types/bun": "^1.3.14",
    "@types/micromatch": "^4.0.10",
    "cross-env": "^10.1.0",
    "eslint": "^10.7.0",
    "knip": "^6.26.0",
    "mlly": "^1.8.2",
    "nodemon": "^3.1.14",
    "openapi3-ts": "^4.6.0",
    "type-fest": "^5.8.0",
    "typescript": "^6.0.3",
    "unimport": "^6.3.0"
